18:13:00.928144 [debug]: Query executed on node model.healthcare_dq.stg_cms_inpatient:
create or replace   view HEALTHCARE_DQ.RAW_STAGING.stg_cms_inpatient
  
  
  
  
  as (
    

SELECT
    -- Provider identifiers
    LPAD(RNDRNG_PRVDR_CCN::VARCHAR, 6, '0')        AS provider_ccn,
    RNDRNG_PRVDR_ORG_NAME                           AS hospital_name,
    RNDRNG_PRVDR_CITY                               AS city,
    RNDRNG_PRVDR_STATE_ABRVTN                       AS state,
    LPAD(RNDRNG_PRVDR_ZIP5::VARCHAR, 5, '0')        AS zip_code,
    RNDRNG_PRVDR_STATE_FIPS::VARCHAR                AS state_fips,
    RNDRNG_PRVDR_RUCA::FLOAT                        AS ruca_code,
    RNDRNG_PRVDR_RUCA_DESC                          AS ruca_description,

    -- Diagnosis & procedure
    LPAD(DRG_CD::VARCHAR, 3, '0')                   AS drg_code,
    DRG_DESC                                        AS drg_description,

    -- Volume & financials
    TOT_DSCHRGS::INTEGER                            AS total_discharges,
    AVG_SUBMTD_CVRD_CHRG::FLOAT                     AS avg_submitted_charge,
    AVG_TOT_PYMT_AMT::FLOAT                         AS avg_total_payment,
    AVG_MDCR_PYMT_AMT::FLOAT                        AS avg_medicare_payment,

    -- Derived metrics
    ROUND(AVG_MDCR_PYMT_AMT / NULLIF(AVG_TOT_PYMT_AMT, 0) * 100, 2) 
                                                    AS medicare_coverage_pct,
    ROUND(AVG_SUBMTD_CVRD_CHRG - AVG_TOT_PYMT_AMT, 2) 
                                                    AS avg_charge_payment_gap,

    -- Metadata
    CURRENT_TIMESTAMP()                             AS _loaded_at,
    '2024'                                          AS data_year

FROM HEALTHCARE_DQ.RAW.CMS_INPATIENT_RAW
  )
/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.healthcare_dq.stg_cms_inpatient", "profile_name": "healthcare_dq", "target_name": "dev"} */
